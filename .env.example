# Environment variables for backend-first local Docker setup

COMPOSE_PROJECT_NAME=microservices-assignment
ENVIRONMENT=development
NODE_ENV=development

ROOM_SERVICE_PORT=5001
SCHEDULE_SERVICE_PORT=5002
BOOKING_SERVICE_PORT=5003
GATEWAY_PORT=8080
FRONTEND_PORT=3000

ROOM_SERVICE_URL=http://room-service:5000
SCHEDULE_SERVICE_URL=http://schedule-service:5000
BOOKING_SERVICE_URL=http://booking-service:5000

FRONTEND_API_BASE_URL=http://localhost:8080
GATEWAY_CORS_ORIGIN=http://localhost:3000

ROOM_DB_HOST=room-db
ROOM_DB_PORT=5432
ROOM_DB_HOST_PORT=5433
ROOM_DB_NAME=room_db
ROOM_DB_USER=room_user
ROOM_DB_PASSWORD=room_pass
ROOM_SERVICE_DB_URL=postgresql://room_user:room_pass@room-db:5432/room_db

SCHEDULE_DB_HOST=schedule-db
SCHEDULE_DB_PORT=5432
SCHEDULE_DB_HOST_PORT=5434
SCHEDULE_DB_NAME=schedule_db
SCHEDULE_DB_USER=schedule_user
SCHEDULE_DB_PASSWORD=schedule_pass
SCHEDULE_SERVICE_DB_URL=postgresql://schedule_user:schedule_pass@schedule-db:5432/schedule_db

BOOKING_DB_HOST=booking-db
BOOKING_DB_PORT=5432
BOOKING_DB_HOST_PORT=5435
BOOKING_DB_NAME=booking_db
BOOKING_DB_USER=booking_user
BOOKING_DB_PASSWORD=booking_pass
BOOKING_SERVICE_DB_URL=postgresql://booking_user:booking_pass@booking-db:5432/booking_db
